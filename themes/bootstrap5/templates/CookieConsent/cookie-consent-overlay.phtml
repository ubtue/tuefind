<div class="cookie-consent__overlay">
  <?php if ($this->deferLoad): ?>
    <div class="load-indicator">
      <?=$this->icon('spinner') ?> <?=$this->transEsc('loading_ellipsis')?>
    </div>
  <?php else: ?>
    <p class="cookie-consent__title">
      <?=$this->translate('CookieConsent::popup_description_html')?>
    </p>

    <?php if ($this->cookieConsent()->isInvalidConsentRevision()): ?>
      <p class="cookie-consent__revision-message">
        <?=$this->translate('CookieConsent::popup_revision_message_html')?>
      </p>
    <?php endif; ?>

    <div class="cookie-consent__settings">
      <?php // Note: Using a p here improves screen reader compatibility e.g. with VoiceOver + Safari ?>
      <p>
        <button class="btn btn-link icon-link cookie-consent__settings-toggle collapsed" type="button"
          data-bs-toggle="collapse" data-bs-target="#cookie_consent_settings_collapse"
          aria-expanded="false" aria-controls="cookie_consent_settings_collapse"
        >
          <?=$this->icon('collapse-open', 'icon-link__icon collapse-icon-open') ?>
          <?=$this->icon('collapse-close', 'icon-link__icon collapse-icon-close') ?>
          <span class="icon-link__label">
            <?=$this->transEsc('CookieConsent::toggle_categories')?>
          </span>
        </button>
      </p>
      <div class="collapse js-settings-collapse" id="cookie_consent_settings_collapse">
        <?=$this->render('CookieConsent/cookie-consent-settings.phtml')?>
      </div>
    </div>

    <div class="cookie-consent__buttons">
      <?php if ($this->cookieConsent()->hasNonEssentialCategories()): ?>
        <button class="btn btn-primary cookie-consent__save-settings js-save-settings hidden">
          <?=$this->transEsc('CookieConsent::Save Settings')?>
        </button>
      <?php endif; ?>
      <button class="btn btn-primary cookie-consent__accept-all js-accept-all">
        <?=$this->transEsc('CookieConsent::Accept All Cookies')?>
      </button>
      <button class="btn btn-primary cookie-consent__accept-essential js-accept-essential">
        <?=$this->transEsc('CookieConsent::Accept Only Essential Cookies')?>
      </button>
    </div>
