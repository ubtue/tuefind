<nav class="banner navbar navbar-expand-md">
  <div class="container">
    <a class="navbar-brand lang-<?=$this->layout()->userLang ?>" href="<?=$this->url('home')?>">VuFind</a>
    <?=$this->notices()->renderNoticesForPosition('header')?>
    <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#header-collapse" aria-label="<?=$this->transEscAttr('mobile_toggle_navigation_text')?>">
      <?=$this->icon('ui-menu') ?>
    </button>
    <?php if (!isset($this->layout()->renderingError)): ?>
      <div class="collapse navbar-collapse justify-content-end" id="header-collapse">
        <?php foreach ($this->menu ?? [] as $group): ?>
          <ul class="nav navbar-nav">
            <?php foreach ($group['MenuItems'] as $item): ?>
              <?php if (isset($item['template'])): ?>
                <?php
                  // Pass section plugin and section context to template.
                  $context = [
                    'sectionPlugin' => $this->{\VuFind\View\Helper\Root\Section::SECTION_PLUGIN_KEY},
                    ...$this->{\VuFind\View\Helper\Root\Section::SECTION_CONTEXT_KEY},
                    ...$item,
                  ];
                ?>
                <?= $this->render($item['template'], $context) ?>
              <?php elseif (isset($item['submenuItems'])): ?>
                <?= $this->component('menu-button', [
                  'toggleLabel' => $item['label'],
                  'toggleAttrs' => [
                    'class' => 'nav-link dropdown-toggle',
                  ],
                  'wrapperClass' => 'nav-item ' . ($item['name'] ?? ''),
                  'wrapperTag' => 'li',
                  'menuItems' => array_map(
                      function ($submenuItem) {
                        $url = isset($submenuItem['route'])
                          ? $this->url($submenuItem['route'], $submenuItem['routeParams'] ?? [])
                          : $submenuItem['url'];
                        return [
                          'label' => $submenuItem['label'],
                          'url' => $url,
                          'description' => $submenuItem['description'] ?? false,
                          'selected' => $this->requestUri === $url,
                        ];
                      },
                      $item['submenuItems'],
                  ),
                ]) ?>
              <?php else: ?>
                <?php
                  $attributes = $this->htmlAttributes($item['attributes'] ?? []);
                  $attributes['href'] = isset($item['route'])
                    ? $this->url($item['route'], $item['routeParams'] ?? [])
                    : $item['url'];
                  $attributes->add('class', 'nav-link');
                  if (isset($item['icon'])) {
                    $attributes->add('class', 'icon-link');
                  }
                ?>
                <li class="nav-item <?=isset($item['name']) ? $this->escAttr($item['name']) : ''?>">
                  <a<?=$attributes?>>
                    <?php if ($icon = $item['icon'] ?? false): ?>
                      <?=$this->icon($icon, 'icon-link__icon') ?>
                      <span class="icon-link__label">
                    <?php endif; ?>
                      <?=$this->transEsc($item['label']) ?>
                    <?php if ($icon): ?>
                      </span>
                    <?php endif; ?>
                  </a>
                </li>
              <?php endif; ?>
            <?php endforeach; ?>
          </ul>
        <?php endforeach; ?>
      </div>
    <?php endif; ?>
  </div>
</nav>
