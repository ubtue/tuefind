<ul>
<?php foreach ($submenuItems as $item): ?>
  <?php $href = isset($item['route']) ? $this->url($item['route'], $item['routeParams'] ?? []) : ($item['url'] ?? null) ?>
  <?php if (isset($item['label']) && ($href || isset($item['submenuItems']))): ?>
    <li>
      <?= $this->makeLink($this->transEsc($item['label']), $href) ?>
      <?php if (isset($item['submenuItems'])): ?>
        <?= $this->render('Section/SiteMap/SiteMap-submenuItems.phtml', ['submenuItems' => $item['submenuItems']]) ?>
      <?php endif; ?>
    </li>
  <?php endif; ?>
<?php endforeach; ?>
</ul>
