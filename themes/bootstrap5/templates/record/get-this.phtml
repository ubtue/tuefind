<?php
# Usually this is displayed in a modal, but if it is not (coming back from login), we don't want the search box.
$this->layout()->searchbox = false;
$templates = $this->getThisLoader->getSubTemplates();
$commentTemplateName = $this->getThisLoader->commentTemplateName();

$recordTitle = $this->driver->getRawData()['title_full'] ?? '';
echo $this->component(
    'page-title',
    [
        'title' => $this->translate('Get This') . ' : ' . $recordTitle,
        'level' => 1,
    ]
);

foreach ($templates as $template) {
    if ($commentTemplateName) {
        echo '<!-- Get-This: ' . $template . ' -->';
    }
    echo $this->context()->renderInContext(
        'record/get-this/' . $template . '.phtml',
        ['getThisParams' => $this->getThisLoader->getSubTemplateParams($template)]
    );
}
