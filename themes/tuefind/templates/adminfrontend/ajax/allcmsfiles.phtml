                    <i class="fas fa-arrow-left me-1"></i> ..
                </span>
            <?php endif; ?>

            <?php $accumulatedPath = '';
            foreach ($pathParts as $folder):
                $accumulatedPath .= ($accumulatedPath === '' ? '' : '/') . $folder;
                $stepFullPath = $baseSyncPath . '/' . $accumulatedPath;
                if (!in_array($folder, $serverFolderArray)) : ?>
                    <span class="btn btn-secondary tf-theme-btn me-1" 
                        data-theme="<?= $this->escapeHtml($accumulatedPath) ?>" 
                        data-full-path="<?= $this->escapeHtml($stepFullPath) ?>" 
                        data-block="AJAXCMSDocsBlock" 
                        data-modetype="<?= $this->escapeHtml($modeType) ?>"
                        data-server-path="<?= $this->escapeHtml($this->serverPath) ?>">
                        <i class="fas fa-folder text-warning me-1"></i>
                        <?= $this->escapeHtml($folder) ?>
                    </span>
                <?php endif; ?>
            <?php endforeach; ?>
        </div>
    </div>

    <div class="row mainCMSDocsBlock">
        <div class="col-md-12">
            <?php if (empty($this->folders)): ?>
                <!--<p class="text-muted">Folders not found</p>-->
            <?php else: ?>
                <div class="show-cms-files-block">
                    <?php foreach ($this->folders as $folder): ?>
                        <span class="btn btn-folder tf-theme-btn" data-theme="<?= $this->escapeHtml($folder['name']) ?>" data-full-path="<?= $this->escapeHtml($this->fullPath . '/' . $folder['name']) ?>" data-server-path="<?= $this->escapeHtml($this->serverPath) ?>" data-block="AJAXCMSDocsBlock" data-modetype="<?= $this->escapeHtml($modeType) ?>">
                            <i class="fas fa-folder me-2 text-warning"></i>
                            <span><?= $this->escapeHtml($folder['name']) ?></span>
                        </span>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </div>
        <p class="delimiter">&nbsp;</p>
        <div class="col-md-12">
            <?php if (empty($this->files)): ?>
                <!--<p class="text-muted">No files with allowed extensions found</p>-->
            <?php else: ?>
                <div class="show-cms-files-block">
                    <?php foreach ($this->files as $file): ?>
                        <?= $this->context($this)->renderInContext('adminfrontend/ajax/node.phtml', ['file' => $file, 'modetype' => $modeType ]) ?>
                    <?php endforeach; ?>
                </div>
            <?php endif; ?>
        </div>
