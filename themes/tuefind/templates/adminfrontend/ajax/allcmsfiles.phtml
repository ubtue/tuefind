<?php
    $baseSyncPath = $this->serverPath;
    $relativePath = ltrim(str_replace($baseSyncPath, '', $this->fullPath), '/');
    $pathParts = array_filter(explode('/', $relativePath));
    $serverFolderArray = explode('/', $this->serverPath);
    $parentFullPath = dirname($this->fullPath);
    if (strlen($parentFullPath) < strlen($baseSyncPath)) {
        $parentFullPath = $baseSyncPath;
    }
    $parentTheme = ltrim(str_replace($baseSyncPath, '', $parentFullPath), '/');
    $modeType = $this->modetype;
?>

